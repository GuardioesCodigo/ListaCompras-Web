@using ListaCompras.WebApplication.ModuloListaCompras.Aplicacao
@using ListaCompras.WebApplication.ModuloItensLista
@model ListaCompras.WebApplication.ModuloItensLista.ItemListaFormViewModel

@{
    Layout = "_Layout";
    
    // Certifique-se de que o tipo aqui corresponda exatamente ao DTO que você envia no Controller
    var lista = ViewBag.Lista as DetalhesListaComprasDto; 
    var itens = ViewBag.Itens as List<ItemListaComprasDto> ?? new List<ItemListaComprasDto>();
    var produtos = ViewBag.ProdutosDisponiveis as List<ListaCompras.WebApplication.ModuloProduto.Dominio.Produto> ?? new List<ListaCompras.WebApplication.ModuloProduto.Dominio.Produto>();
    
    ViewBag.Titulo = $"Gerenciando: {lista?.Nome ?? "Lista de Compras"}";
}

<div class="container mt-5"">
    
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-primary m-0">@lista?.Nome</h2>
            <p class="text-muted m-0">
                Criada em @(lista?.DataCriacao.ToString("dd/MM/yyyy")) | 
                Status: <span class="fw-semibold text-success">@lista?.Status</span>
            </p>
        </div>
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <small class="text-uppercase tracking-wider opacity-75">Total da Lista</small>
            <h3 class="fw-bold m-0">R$ @(lista?.TotalGasto.ToString("N2") ?? "0,00")</h3>
        </div>
    </div>

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Erro"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Sucesso"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }


    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <h5 class="fw-bold text-primary mb-3">Adicionar Item à Lista</h5>
        <form action="/ItensLista/Adicionar" method="post">
            <input type="hidden" asp-for="ListaComprasId" />

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">Produto</label>
                    <select asp-for="ProdutoId" class="form-select form-select-lg rounded-3 shadow-sm" required>
                        <option value="">Selecione um produto</option>
                        @foreach (var p in produtos)
                        {
                            <option value="@p.Id">@p.Nome (R$ @p.PrecoAproximado.ToString("N2"))</option>
                        }
                    </select>
                    <span asp-validation-for="ProdutoId" class="text-danger small"></span>
                </div>

                <div class="col-md-3">
                    <label class="form-label fw-semibold">Quantidade</label>
                    <input asp-for="Quantidade" type="number" class="form-control form-control-lg rounded-3 shadow-sm" min="1" value="1">
                    <span asp-validation-for="Quantidade" class="text-danger small"></span>
                </div>

                <div class="col-md-3 d-flex align-items-end">
                    <button class="btn btn-primary btn-lg rounded-pill w-100 shadow-sm" type="submit">
                        <i class="bi bi-cart-plus me-2"></i>Inserir
                    </button>
                </div>
            </div>
        </form>
    </div>

    <h4 class="fw-bold text-secondary mb-3">Produtos na Lista</h4>
    @if (itens.Count == 0)
    {
        <div class="alert alert-secondary border-0 shadow-sm rounded-4 p-4">Nenhum produto adicionado ainda.</div>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Produto</th>
                            <th>Categoria</th>
                            <th>Quantidade</th>
                            <th>Preço Unitário</th>
                            <th>Subtotal</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in itens)
                        {
                            <tr>
                                <td class="fw-semibold text-dark">@item.NomeProduto</td>
                                <td><span class="badge bg-secondary-subtle text-secondary px-2.5 py-1.5 rounded">@item.CategoriaProduto</span></td>
                                <td>@item.Quantidade</td>
                                <td>R$ @item.PrecoUnitario.ToString("N2")</td>
                                <td class="fw-bold text-primary">R$ @((item.Quantidade * item.PrecoUnitario).ToString("N2"))</td>
                                <td>
                                    <div class="d-flex justify-content-center">
                                        <form action="/ItensLista/Remover" method="post" onsubmit="return confirm('Remover este item?')">
                                            <input type="hidden" name="listaId" value="@lista?.Id" />
                                            <input type="hidden" name="itemId" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3">Remover</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    <div class="mt-3 mb-5">
        <a class="btn btn-outline-secondary rounded-pill px-4" href="/ListaCompras/Listar">Voltar para Listas</a>
    </div>
</div>