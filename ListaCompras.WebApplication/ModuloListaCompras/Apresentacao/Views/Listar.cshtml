
@{
    Layout = "_layout";
}

@using ListaCompras.WebApplication.ModuloListaCompras.Apresentacao;
@using ListaCompras.WebApplication.ModuloItensLista;
@model IEnumerable<ListaComprasViewModel>

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <title>Minhas Listas de Compras</title>
</head>
<body>
<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Gerenciador de Listas de Compras</h2>

        <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-action="Cadastrar">
            <i class="bi bi-plus-lg me-2"></i>Nova Lista
        </a>
    </div>

    @if (TempData["Erro"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["Erro"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (TempData["Sucesso"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["Sucesso"]

            <button type="button"
                    class="btn-close"
                    data-bs-dismiss="alert">
            </button>
        </div>
    }

    @if (Model == null || !Model.Any())
    {
        <p>Nenhuma lista de compras cadastrada de verdade no arquivo.</p>
    }
    else
    {
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 tabela-custom">
                    <thead>
                        <tr>
                            <th>Nome da Lista</th>
                            <th>Data de Criação</th>
                            <th>Status</th>
                            <th class="text-center">Ações</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var lista in Model)
                        {
                            <tr>
                                <td><strong>@lista.Nome</strong></td>
                                <td>@lista.DataCriacaoFormatada</td>
                                <td>@lista.Status</td>
                                <td>
                                    
                                    <div class="d-flex justify-content-center gap-2">

                                        <form action="/ListaCompras/Editar/@lista.Id" method="get" style="display:inline;">
                                            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" type="submit">Editar</button>
                                        </form>
                                        
                                        <form action="/ListaCompras/Excluir" method="post"  style="display:inline;" >
                                            <input type="hidden" name="id" value="@lista.Id" />
                                            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" type="submit">Excluir</button>
                                        </form>
                                        <form action="/ItensLista/Gerenciar/?listaId=@lista.Id" method="post" style="display:inline;">
                                            <input type="hidden" name="id" value="@lista.Id" />
                                            <button class="btn btn-outline-primary btn-sm rounded-pill px-3" type="submit">Adicionar Item</button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>
</body>
</html>