@using ListaCompras.WebApplication.ModuloProduto.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Produtos";
}

@model ExcluirProdutosViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-action="Excluir"
          asp-route-id="@Model.Id"
          method="post">

        <input type="hidden" asp-for="Id" />

        <h3 class="fw-bold text-primary mb-3">Excluir Produto</h3>

        <div class="alert alert-info rounded-3 shadow-sm mb-4">
            Deseja realmente excluir este produto?
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Nome</label>
            <input value="@Model.Nome"
                   class="form-control form-control-lg rounded-3 shadow-sm"
                   readonly />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Categoria</label>
            <input value="@Model.CategoriaId"
                   class="form-control form-control-lg rounded-3 shadow-sm"
                   readonly />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Unidade de Medida</label>
            <input value="@Model.UnidadeMedida"
                   class="form-control form-control-lg rounded-3 shadow-sm"
                   readonly />
        </div>

        <div class="mb-4">
            <label class="form-label fw-semibold">Preço Aproximado</label>
            <input value="R$ @Model.PrecoAproximado"
                   class="form-control form-control-lg rounded-3 shadow-sm"
                   readonly />
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-action="Listar"
               class="btn btn-outline-secondary rounded-pill px-4 py-2">
                Voltar
            </a>

            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm"
                    type="submit">
                Excluir
            </button>
        </div>

    </form>

</div>