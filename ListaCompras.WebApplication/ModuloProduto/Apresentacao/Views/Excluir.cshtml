@using ListaCompras.WebApplication.ModuloProduto.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Produtos";
}

@model ExcluirProdutosViewModel

<form class="card border-primary-subtle shadow-sm mx-auto p-4"
      style="max-width: 620px;"
      asp-action="Excluir"
      asp-route-id="@Model.Id"
      method="post">

    <div class="alert alert-primary border-start border-primary border-2 rounded-3" role="alert">
        Tem certeza que deseja excluir este produto?
    </div>

    <dl class="row mb-0">

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">ID</dt>
        <dd class="col-sm-8">@Model.Id</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Nome</dt>
        <dd class="col-sm-8">@Model.Nome</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Categoria</dt>
        <dd class="col-sm-8">@Model.CategoriaId</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Unidade de Medida</dt>
        <dd class="col-sm-8">@Model.UnidadeMedida</dd>

        <dt class="col-sm-4 fw-semibold text-primary text-uppercase small">Preço Aproximado</dt>
        <dd class="col-sm-8">R$ @Model.PrecoAproximado</dd>

    </dl>

    <div class="d-flex justify-content-end gap-2 mt-4">
        <a class="btn btn-outline-primary rounded-pill px-4" asp-action="Listar">
            Voltar
        </a>

        <button class="btn btn-primary rounded-pill px-4" type="submit">
            Confirmar
        </button>
    </div>

</form>