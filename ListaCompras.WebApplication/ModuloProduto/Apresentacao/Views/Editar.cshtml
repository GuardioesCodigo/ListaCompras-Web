@using ListaCompras.WebApplication.ModuloProduto.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Edição de Produtos";
}

@model EditarProdutoViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-action="Editar"
          method="post">

        <input type="hidden" asp-for="Id" />

        <h3 class="fw-bold text-primary mb-3">Editar Produto</h3>

        <div class="alert alert-info rounded-3 shadow-sm mb-4">
            Altere as informações do produto.
        </div>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

            <select asp-for="CategoriaId" asp-items="ViewBag.Categoria"
                    class="form-select">
                <option value="">Selecione uma categoria</option>
            </select>

        <div class="mb-4">
            <label asp-for="UnidadeMedida" class="form-label fw-semibold">Unidade de medida</label>
            <select asp-for="UnidadeMedida" class="form-select form-select-lg rounded-3 shadow-sm">
                <option value="">Selecione a unidade</option>
                <option value="kg">kg</option>
                <option value="unidade">unidade</option>
                <option value="litro">litro</option>
                <option value="caixa">caixa</option>
            </select>
            <span asp-validation-for="UnidadeMedida" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="PrecoAproximado" class="form-label fw-semibold">Preço Aproximado</label>
            <input asp-for="PrecoAproximado" type="number" step="0.01" min="0"
                   class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="PrecoAproximado" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                Voltar
            </a>

            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm" type="submit">
                Salvar
            </button>
        </div>

    </form>
</div>