@using ListaCompras.WebApplication.ModuloProduto.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Produtos";
}

@model CadastrarProdutoViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-action="Cadastrar"
          method="post">

        <h3 class="fw-bold text-primary mb-4">Cadastro de Produto</h3>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Categoria" class="form-label fw-semibold">Categoria</label>
            <select asp-for="Categoria" class="form-select form-select-lg rounded-3 shadow-sm">
                <option value="">Selecione uma categoria</option>
                <!-- Exemplo de opções -->
                <option value="Alimentos">Alimentos</option>
                <option value="Limpeza">Limpeza</option>
                <option value="Higiene">Higiene</option>
                <option value="Outros">Outros</option>
            </select>
            <span asp-validation-for="Categoria" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="UnidadeDeMedida" class="form-label fw-semibold">Unidade de medida</label>
            <select asp-for="UnidadeDeMedida" class="form-select form-select-lg rounded-3 shadow-sm">
                <option value="">Selecione a unidade</option>
                <option value="kg">kg</option>
                <option value="unidade">unidade</option>
                <option value="litro">litro</option>
                <option value="caixa">caixa</option>
            </select>
            <span asp-validation-for="UnidadeDeMedida" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="PrecoAproximado" class="form-label fw-semibold">Preço aproximado</label>
            <input asp-for="PrecoAproximado" type="number" step="0.01"
                   class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="PrecoAproximado" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">

            <a class="btn btn-outline-secondary rounded-pill px-4 py-2"
               asp-action="Listar">
                Voltar
            </a>

            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm"
                    type="submit">
                Confirmar
            </button>

        </div>
    </form>
</div>
