@using ListaCompras.WebApplication.ModuloProduto.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Produtos";
}

@model List<ListarProdutosViewModel>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Produtos</h2>

        <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-action="Cadastrar">
            <i class="bi bi-plus-lg me-2"></i>Novo Produto
        </a>
    </div>

@if (Model.Count == 0)
{
    <div class="alert alert-primary border-0 shadow-sm rounded-4 p-4">
        Nenhum produto cadastrado.
    </div>
}
else
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 tabela-custom">

                <thead class="table-secondary">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Categoria</th>
                        <th>Unidade de Medida</th>
                        <th>Preço Aproximado</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (ListarProdutosViewModel p in Model)
                    {
                        <tr>
                            <td>@p.Id</td>
                            <td>@p.Nome</td>
                            <td>@p.Categoria</td>
                            <td>@p.UnidadeMedida</td>
                            <td>R$ @p.PrecoAproximado.ToString("N2")</td>

                            <td>
                                <div class="d-flex justify-content-center gap-2">

                                    <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                       asp-action="Editar"
                                       asp-route-id="@p.Id">
                                        Editar
                                    </a>

                                    <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                       asp-action="Excluir"
                                       asp-route-id="@p.Id">
                                        Excluir
                                    </a>

                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
</div>
