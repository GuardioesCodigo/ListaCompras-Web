@{
    Layout = "_Layout";
    ViewBag.Titulo = "Home";
}

<div class="row g-2">
    <div class="col-lg-7">
        <h1 class="display-5 fw-semibold mb-3">Lista de Compras</h1>
        <p class="lead text-secondary mb-4">
            Lista de compras do mês
        </p>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Categoria" asp-action="Listar">Listar Categoria</a>
        </div>

        <div class="d-flex flex-wrap gap-2">
            <a class="btn btn-primary rounded-pill px-4" asp-controller="Produto" asp-action="Listar">Listar Produto</a>
        </div>
    </div>
</div>