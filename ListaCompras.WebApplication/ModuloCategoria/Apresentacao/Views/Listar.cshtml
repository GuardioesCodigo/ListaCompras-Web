@using ListaCompras.WebApplication.ModuloCategoria.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Categorias";
}

@model List<ListarCategoriasViewModel>

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-primary m-0">Categorias de Compras</h2>
        <a class="btn btn-primary rounded-pill px-4 shadow-sm" asp-action="Cadastrar">
            <i class="bi bi-plus-lg me-2"></i>Nova Categoria
        </a>
    </div>

    <div class="filtros-listagem">

        <a asp-action="Listar"
            class="btn btn-outline-primary @(string.IsNullOrEmpty(Context.Request.Query["status"]) ? "active" : "")">
            Todos
        </a>

        <a asp-action="Listar" asp-route-status="Branca"
            class="btn btn-outline-primary @(Context.Request.Query["status"] == "Branca" ? "active" : "")">
            Branca
        </a>

        <a asp-action="Listar" asp-route-status="Vermelha"
            class="btn btn-outline-primary @(Context.Request.Query["status"] == "Vermelha" ? "active" : "")">
            Vermelha
        </a>

        <a asp-action="Listar" asp-route-status="Verde"
            class="btn btn-outline-primary @(Context.Request.Query["status"] == "Verde" ? "active" : "")">
            Verde
        </a>

        <a asp-action="Listar" asp-route-status="Azul"
            class="btn btn-outline-primary @(Context.Request.Query["status"] == "Azul" ? "active" : "")">
            Azul
        </a>

    </div>

@if (Model.Count == 0)
{
    <div class="alert alert-warning border-0 shadow-sm rounded-4 p-4">
        Nenhuma categoria cadastrada.
    </div>
}
else 
{
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0 tabela-custom">

                <thead class="table-secondary">
                    <tr>
                        <th>ID</th>
                        <th>Nome</th>
                        <th>Cor</th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (ListarCategoriasViewModel c in Model)
                    {
                        <tr>
                            <td>@c.Id</td>
                            <td>@c.Nome</td>
                            <td>@c.Cor</td>
                            <td>
                                <div class="d-flex justify-content-center gap-2">

                                    <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                        asp-action="Editar"
                                        asp-route-id="@c.Id">Editar</a>

                                    <a class="btn btn-outline-primary btn-sm rounded-pill px-3"
                                        asp-action="Excluir"
                                        asp-route-id="@c.Id">Excluir</a>
                                </div>

                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
</div>
