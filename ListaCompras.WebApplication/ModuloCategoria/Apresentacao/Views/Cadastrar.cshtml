@using ListaCompras.WebApplication.ModuloCategoria.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Listagem de Categorias";
}

@model CadastrarCategoriasViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-action="Cadastrar"
          method="post">

        <h3 class="fw-bold text-primary mb-4">Cadastro de Categoria</h3>

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm">
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Cor" class="form-label fw-semibold">Cor</label>
            <select asp-for="Cor" class="form-select form-select-lg rounded-3 shadow-sm">
                <option value="Nenhuma">Selecione uma cor</option>
                <option value="Branca">Branca</option>
                <option value="Vermelha">Vermelha</option>
                <option value="Verde">Verde</option>
                <option value="Azul">Azul</option>
            </select>
            <span asp-validation-for="Cor" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">

            <a class="btn btn-outline-secondary rounded-pill px-4 py-2"
               asp-action="Listar">
                Voltar
            </a>

            <button class="btn btn-primary rounded-pill px-4 py-2 shadow-sm"
                    type="submit">
                Confirmar
            </button>

        </div>
    </form>
</div>