@using ListaCompras.WebApplication.ModuloCategoria.Apresentacao
@{
    Layout = "_Layout";
    ViewBag.Titulo = "Exclusão de Categorias";
}

@model ExcluirCategoriasViewModel

<div class="container d-flex justify-content-center align-items-center"
     style="min-height: calc(100vh - 120px);">

    <form class="card border-0 shadow-lg p-4 rounded-4 w-100"
          style="max-width: 620px;"
          asp-action="Excluir"
          method="post">

        <input type="hidden" asp-for="Id" />

        <h3 class="fw-bold text-danger mb-3">Excluir Categoria</h3>

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold small"></div>

        @if (ViewBag.MensagemErro != null)
        {
            <div class="alert alert-danger border-0 shadow-sm rounded-3 fw-bold mb-4">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @ViewBag.MensagemErro
            </div>
        }
        else
        {
            <div class="alert alert-warning rounded-3 shadow-sm mb-4">
                Deseja realmente excluir essa categoria?
            </div>
        }

        <div class="mb-4">
            <label asp-for="Nome" class="form-label fw-semibold">Nome</label>
            <input asp-for="Nome" type="text" class="form-control form-control-lg rounded-3 shadow-sm" readonly>
            <span asp-validation-for="Nome" class="text-danger small"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Cor" class="form-label fw-semibold">Cor</label>
            <input asp-for="Cor" type="text" class="form-control form-control-lg rounded-3 shadow-sm" readonly>
            <span asp-validation-for="Cor" class="text-danger small"></span>
        </div>

        <div class="d-flex justify-content-end gap-3 mt-4">
            <a asp-action="Listar" class="btn btn-outline-secondary rounded-pill px-4 py-2">
                Voltar
            </a>

            <button class="btn btn-danger rounded-pill px-4 py-2 shadow-sm"
                    type="submit"
                    @(ViewBag.MensagemErro != null ? "disabled" : "")>
                Excluir
            </button>
        </div>

    </form>
</div>